{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "job-input.schema.json",
  "type": "object",
  "required": ["source_materials", "transcript"],
  "properties": {
    "source_materials": {
      "type": "object",
      "required": ["financial_reports", "disclaimer"],
      "properties": {
        "financial_reports": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "earnings_transcript": {"type": ["string", "null"]},
        "supplementary_files": {"type": "array", "items": {"type": "string"}, "default": []},
        "disclaimer": {"type": "string", "minLength": 1}
      }
    },
    "content_requirements": {"type": ["object", "null"]},
    "transcript": {
      "type": "object",
      "required": ["mode", "language"],
      "properties": {
        "mode": {"enum": ["generate", "pre-written"]},
        "text": {"type": ["string", "null"]},
        "allow_editing": {"type": "boolean", "default": true},
        "language": {"type": "string", "default": "zh-CN"}
      },
      "allOf": [{"if": {"properties": {"mode": {"const": "pre-written"}}}, "then": {"required": ["text"], "properties": {"text": {"type": "string", "minLength": 1}}}}]
    },
    "creative_direction": {"type": "object"},
    "audio": {"type": "object"},
    "captions": {"type": "object"},
    "brand": {"type": "object"},
    "output": {"type": "object"}
  }
}
