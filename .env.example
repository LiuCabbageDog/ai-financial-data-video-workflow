# ----------------------------------------------------------------------------
# Application and runtime
# ----------------------------------------------------------------------------
APP_ENV=local
ADAPTER_MODE=deterministic
ARTIFACT_ROOT=./runs
REQUEST_TIMEOUT_SECONDS=600
REMOTION_CONCURRENCY=2

# ----------------------------------------------------------------------------
# OpenAI planning
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# LLM narration estimates must stay within target duration ± this ratio.
NARRATION_PLANNING_TOLERANCE=0.10
NARRATION_REWRITE_ATTEMPTS=3
MANDARIN_CHARS_PER_SECOND=4.4 # Need to be adjusted based on voice ID you choose.

# ----------------------------------------------------------------------------
# ElevenLabs narration
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Base delivery and Voice characteristics.
ELEVENLABS_SPEED=1.02
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0
ELEVENLABS_USE_SPEAKER_BOOST=true

# Real TTS audio must stay within target duration ± this ratio.
TARGET_DURATION_TOLERANCE=0.15
TTS_AUTO_FIT_DURATION=true

# ----------------------------------------------------------------------------
# BACH visual generation
# ----------------------------------------------------------------------------
BACH_ACCESS_KEY=
BACH_SECRET_KEY=
BACH_BASE_URL=https://api-gen-na.bach.art/api/vdr
BACH_MODEL_NAME=bach-1.0-preview
BACH_RESOLUTION=1080p
BACH_POLL_INTERVAL_SECONDS=10

# Provider endpoint paths.
BACH_TEXT_TO_VIDEO_PATH=/videos/text2video
BACH_ELEMENTS_TO_VIDEO_PATH=/videos/elements2video
BACH_TEXT_TO_IMAGE_PATH=/images/text2image
BACH_TEXT_TO_SUBJECT_PATH=/subject/text2image

# ----------------------------------------------------------------------------
# Optional cost estimates (set these to current contract rates)
# ----------------------------------------------------------------------------
OPENAI_INPUT_USD_PER_MILLION=0
OPENAI_OUTPUT_USD_PER_MILLION=0
ELEVENLABS_USD_PER_THOUSAND_CHARS=0
BACH_VIDEO_USD_PER_CALL=0
BACH_IMAGE_USD_PER_CALL=0
